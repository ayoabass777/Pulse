{
    "type": "kafka",
    "spec": {
      "dataSchema": {
        "dataSource": "user-activity-streams",
        "timestampSpec": {
          "column": "timestamp",
          "format": "iso"
        },
        "dimensionsSpec": {
          "dimensions": [
            "user_id",
            "event_type",
            "page",
            "product_id",
            "category",
            "price",
            "search_query"
          ]
        },
        "metricsSpec": [],
        "granularitySpec": {
          "type": "uniform",
          "segmentGranularity": "hour",
          "queryGranularity": "none",
          "rollup": false
        }
      },
      "ioConfig": {
        "topic": "user_activity",
        "inputFormat": {
          "type": "json",
          "flattenSpec": {
            "useFieldDiscovery": false,
            "fields": [
              { "name": "user_id",      "type": "path", "expr": "$.user_id" },
              { "name": "event_type",   "type": "path", "expr": "$.event_type" },
              { "name": "page",         "type": "path", "expr": "$.page" },
              { "name": "product_id",   "type": "path", "expr": "$.metadata.product_id" },
              { "name": "category",     "type": "path", "expr": "$.metadata.category" },
              { "name": "price",        "type": "path", "expr": "$.metadata.price" },
              { "name": "search_query", "type": "path", "expr": "$.metadata.search_query" }
            ]
          }
        },
        "consumerProperties": {
          "bootstrap.servers": "kafka:9092"
        },
        "taskCount": 1,
        "replicas": 1,
        "taskDuration": "PT10M",
        "useEarliestOffset": true
      },
      "tuningConfig": {
        "type": "kafka"
      }
    }
  }